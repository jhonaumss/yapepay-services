PORT=8000
AWS_REGION=us-east-1

DB_HOST=localhost
DB_PORT=5433
DB_USER=yapepay
DB_PASSWORD=yapepay123
DB_NAME=yapepay_credit
DB_SSL=false

# Leave empty locally to disable the feature-materialization consumer.
SQS_QUEUE_URL=

S3_MODEL_BUCKET=yapepay-dev-ml-artifacts-<account-id>-<region>

# MLFLOW_TRACKING_URI itself is resolved by training/src/config.py — leave
# unset locally to use its sqlite fallback, or set MLFLOW_DB_HOST (+ _PORT/_USER/
# _PASSWORD/_NAME) to point at the shared Postgres instance directly, matching
# how services-stack.ts wires it in deployed environments.
# Use "candidate" locally to test a freshly trained model before it's promoted.
MLFLOW_MODEL_ALIAS=production

COGNITO_USER_POOL_ID=
INTERNAL_API_KEY=

RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
